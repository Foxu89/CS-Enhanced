<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/primaryBlackBackground">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="?attr/primaryBlackBackground"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            style="@style/BlackButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            app:icon="@drawable/ic_baseline_arrow_back_24"
            app:iconGravity="textStart"
            app:iconSize="24dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/actorImage"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/roundedImageView"
            android:src="@drawable/ic_baseline_person_24"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/actorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:text="Name"
                android:textColor="?attr/textColor"
                android:fontFamily="@font/google_sans"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/filmographyCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:text="0 Filmography"
                android:textColor="?attr/grayTextColor"
                android:fontFamily="@font/google_sans"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Filter Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/actor_filter"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/grayTextColor"
            android:fontFamily="@font/google_sans"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/filterAll"
                    style="@style/FilterButton"
                    android:text="@string/actor_all"
                    android:selected="true"/>

                <Button
                    android:id="@+id/filterMovies"
                    style="@style/FilterButton"
                    android:text="@string/actor_movies"
                    android:layout_marginStart="8dp"/>

                <Button
                    android:id="@+id/filterTv"
                    style="@style/FilterButton"
                    android:text="@string/actor_tv_shows"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Sort Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/actor_sort_by"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?attr/grayTextColor"
            android:fontFamily="@font/google_sans"
            android:textAllCaps="true"
            android:layout_marginBottom="8dp"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/sortPopularity"
                    style="@style/SortButton"
                    android:text="@string/actor_popularity"
                    android:drawableStart="@drawable/ic_baseline_trending_up_24"
                    android:selected="true"/>

                <Button
                    android:id="@+id/sortLatest"
                    style="@style/SortButton"
                    android:text="@string/actor_latest"
                    android:drawableStart="@drawable/ic_baseline_schedule_24"
                    android:layout_marginStart="8dp"/>

                <Button
                    android:id="@+id/sortUpcoming"
                    style="@style/SortButton"
                    android:text="@string/actor_upcoming"
                    android:drawableStart="@drawable/ic_baseline_event_24"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Loading Indicator -->
    <ProgressBar
        android:id="@+id/loadingIndicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:visibility="gone"/>

    <!-- Empty View -->
    <include
        android:id="@+id/emptyView"
        layout="@layout/empty_state_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/filmographyRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="20dp"
        android:clipToPadding="false"
        android:visibility="visible"/>
</LinearLayout>
